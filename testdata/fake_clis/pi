#!/bin/sh
set -eu

session_path=""
rpc_mode=""

while [ "$#" -gt 0 ]; do
  case "$1" in
    --version|-v)
      printf '%s\n' 'fake-pi 0.0.1'
      exit 0
      ;;
    --help|-h)
      cat <<'EOF'
pi - AI coding assistant with read, bash, edit, write tools

Options:
  --provider <name>              Provider name (default: google)
  --model <id>                   Model ID (default: gemini-2.5-flash)
  --list-models [search]         List available models (with optional fuzzy search)
  --mode <mode>                  Output mode: text (default), json, or rpc
EOF
      exit 0
      ;;
    --list-models)
      cat <<'EOF'
provider  model              context  max-out  thinking  images
google    gemini-2.5-flash   1.0M     65.5K    yes       yes
openai    gpt-4o-mini        128K     16K      no        yes
zai       glm-5              128K     16K      no        no
EOF
      exit 0
      ;;
    --session)
      shift
      session_path="${1:-}"
      ;;
    --mode)
      shift
      rpc_mode="${1:-}"
      ;;
  esac
  shift
done

if [ "$rpc_mode" = "rpc" ]; then
  while IFS= read -r line; do
    cmd_type=$(echo "$line" | sed 's/.*"type"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' | head -1)
    cmd_id=$(echo "$line" | sed 's/.*"id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' | head -1)

    case "$cmd_type" in
      get_state)
        printf '{"id":"%s","type":"response","command":"get_state","success":true,"data":{"sessionId":"fake-session-123","thinkingLevel":"off","isStreaming":false,"isCompacting":false,"steeringMode":"one-at-a-time","followUpMode":"one-at-a-time","autoCompactionEnabled":false,"messageCount":0,"pendingMessageCount":0}}\n' "$cmd_id"
        ;;
      prompt)
        printf '{"id":"%s","type":"response","command":"prompt","success":true}\n' "$cmd_id"
        printf '{"type":"agent_start"}\n'
        printf '{"type":"turn_start"}\n'
        printf '{"type":"message_start","message":{"role":"assistant","content":[]}}\n'
        printf '{"type":"message_update","message":{"role":"assistant"},"assistantMessageEvent":{"type":"text_delta","delta":"Fake Pi response."}}\n'
        printf '{"type":"message_end","message":{"role":"assistant","content":[{"type":"text","text":"Fake Pi response."}]}}\n'
        printf '{"type":"turn_end","message":{"role":"assistant","content":[{"type":"text","text":"Fake Pi response."}]}}\n'
        printf '{"type":"agent_end","messages":[]}\n'
        ;;
      steer)
        printf '{"id":"%s","type":"response","command":"steer","success":true}\n' "$cmd_id"
        ;;
      follow_up)
        printf '{"id":"%s","type":"response","command":"follow_up","success":true}\n' "$cmd_id"
        ;;
      abort)
        printf '{"id":"%s","type":"response","command":"abort","success":true}\n' "$cmd_id"
        printf '{"type":"turn_end","message":{"role":"assistant","content":[]}}\n'
        printf '{"type":"agent_end","messages":[]}\n'
        ;;
      *)
        printf '{"type":"response","command":"%s","success":false,"error":"Unknown command: %s"}\n' "$cmd_type" "$cmd_type"
        ;;
    esac
  done
  exit 0
fi

mode="run"
if [ -n "$session_path" ]; then
  mkdir -p "$(dirname "$session_path")"
  if [ -s "$session_path" ]; then
    mode="continue"
  fi
  printf '%s\n' 'pi-session-123' > "$session_path"
fi

printf '%s\n' '{"type":"session","id":"pi-session-123"}'
if [ "$mode" = "continue" ]; then
  printf '%s\n' '{"type":"assistant","text":"Pi continued the task"}'
else
  printf '%s\n' '{"type":"assistant","text":"Pi completed the task"}'
fi
